# LLM Provider: "openai" (default) or "ollama"
LLM_PROVIDER=openai

# OpenAI settings (used when LLM_PROVIDER=openai)
# NOTE: In production, store API keys via the admin panel (/admin/login) instead of this env var.
# The env var is only used as a fallback if no keys exist in the database.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/codelens
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/codelens

# CORS — comma-separated frontend URLs allowed (e.g. https://app.vercel.app,https://my-domain.com)
# Leave empty for local development defaults
ALLOWED_ORIGINS=

# Admin panel (for managing API keys at /admin)
ADMIN_PASSWORD=admin
ENCRYPTION_KEY=

# GitHub (optional — avoids rate limits)
GITHUB_TOKEN=
